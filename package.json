{
  "name": "jetstream-weather",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Production-oriented React and Node weather application.",
  "engines": {
    "node": ">=20.11.0"
  },
  "workspaces": [
    "packages/domain",
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "coverage": "npm run coverage --workspaces",
    "dev": "npm run build -w @jetstream-weather/domain && concurrently \"npm run dev -w @jetstream-weather/api\" \"npm run dev -w @jetstream-weather/web\"",
    "lint": "eslint .",
    "pretest": "npm run build -w @jetstream-weather/domain",
    "pretypecheck": "npm run build -w @jetstream-weather/domain",
    "test": "npm run test --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vitest": "^3.1.2"
  }
}
