{
  "name": "@jetstream-weather/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "coverage": "vitest run --coverage",
    "dev": "vite --host 0.0.0.0",
