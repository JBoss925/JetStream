{
  "name": "@jetstream-weather/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "coverage": "vitest run --config vitest.config.ts --coverage",
