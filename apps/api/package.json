    "@jetstream-weather/domain": "0.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.3",
    "@types/swagger-ui-express": "^4.1.8",
    "tsx": "^4.8.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
