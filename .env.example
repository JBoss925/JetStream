# Backend mode is the default.
VITE_API_BASE_URL=http://localhost:3000

# Secret data source toggle:
# - backend: use the NestJS API and Swagger-backed BFF
# - direct: call Open-Meteo directly from the browser for frontend-only hosting
VITE_WEATHER_DATA_SOURCE=backend

# Optional API server config.
PORT=3000
CORS_ORIGIN=http://localhost:5173
